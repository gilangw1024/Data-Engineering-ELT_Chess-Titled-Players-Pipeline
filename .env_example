# ==========================================
# CHESS TITLED PLAYERS ANALYTICS PIPELINE
# Environment Configuration (.env.example)
# ==========================================

# ------------------------------------------
# 1. DOCKER CONFIGURATION (PENTING UNTUK PERMISSION)
# ------------------------------------------
AIRFLOW_UID=50000

# ------------------------------------------
# 2. AIRFLOW CONFIGURATION
# ------------------------------------------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__WEBSERVER__SECRET_KEY=ganti_dengan_secret_key_acak_anda
AIRFLOW__CORE__FERNET_KEY=ganti_dengan_fernet_key_python

# ------------------------------------------
# 3. POSTGRESQL CONFIGURATION (DATA WAREHOUSE)
# ------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password_anda
POSTGRES_DB=chess_warehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ------------------------------------------
# 4. MONGODB CONFIGURATION (RAW STORAGE)
# ------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password_anda
MONGO_INITDB_DATABASE=chess_raw
MONGO_HOST=mongodb
MONGO_PORT=27017

MONGO_URI=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/?authSource=admin

# ------------------------------------------
# 5. CHESS.COM API CONFIGURATION
# ------------------------------------------
CHESS_API_BASE_URL=https://api.chess.com/pub
CHESS_API_RATE_LIMIT_DELAY=1

# ------------------------------------------
# 6. GENERAL APP SETTINGS
# ------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ------------------------------------------
# 7. OPTIONAL TUNING
# ------------------------------------------
MAX_RETRIES=5
BACKOFF_FACTOR=2.0
REQUEST_TIMEOUT=30
BATCH_SIZE=100
